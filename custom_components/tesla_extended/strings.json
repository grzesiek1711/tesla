  "services": {
    "api": {
      "name": "Run API Command",
      "description": "Run an API command using controller.api",
      "fields": {
        "email": {
          "name": "Email address",
          "description": "Email address (optional if only one account)"
        },
        "command": {
          "name": "Command",
          "description": "Command to run. Examples: WAKE_UP, CLIMATE_ON, START_CHARGE"
        },
        "parameters": {
          "name": "Parameters",
          "description": "Parameters as a dictionary. Use `path_vars` to replace endpoint variables. Other parameters are passed directly to the API controller."
        }
      }
    },
    "polling_interval": {
      "name": "Set Polling Interval",
      "description": "Set the polling interval for the Tesla API",
      "fields": {
        "scan_interval": {
          "name": "Interval (seconds)",
          "description": "Number of seconds between each poll. Use -1 for adaptive polling, or specify 1-3600 seconds for manual intervals."
        },
        "email": {
          "name": "Email address",
          "description": "Email address (optional if only one account)"
        },
        "vin": {
          "name": "Vehicle VIN",
          "description": "Vehicle VIN (if not provided then default polling interval will be updated)"
        }
      }
    }
